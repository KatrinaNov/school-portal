{
  "name": "school-portal",
  "version": "1.0.0",
  "description": "Учебная тестовая система",
  "private": true,
  "scripts": {
    "test": "node node_modules/jest/bin/jest.js --config jest.config.cjs",
    "test:coverage": "node node_modules/jest/bin/jest.js --config jest.config.cjs --coverage",
    "dev": "webpack serve --config webpack.config.cjs --mode development",
    "build": "webpack --config webpack.config.cjs --mode production",
    "migrate:firestore": "node scripts/migrate-to-firestore.mjs",
    "lint": "eslint .",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "validate:data": "node scripts/validate-data.mjs"
  },
  "devDependencies": {
    "copy-webpack-plugin": "^14.0.0",
    "eslint": "^9.35.0",
    "html-webpack-plugin": "^5.6.6",
    "jest": "^29.7.0",
    "prettier": "^3.6.2",
    "script-loader": "^0.7.2",
    "webpack": "^5.105.4",
    "webpack-cli": "^7.0.2",
    "webpack-dev-server": "^5.2.3"
  },
  "dependencies": {
    "firebase": "^12.10.0",
    "firebase-admin": "^13.7.0"
  }
}
