rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // Content is readable by everyone (so app can stay public/guest-friendly).
    match /classes/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /subjects/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /paragraphs/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /quizzes/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Admin snapshot (optional). Used by admin panel for quick load.
    match /adminData/{id} {
      allow read, write: if isAdmin();
    }

    // Users and stats
    match /users/{uid} {
      allow read: if isAdmin() || (isSignedIn() && request.auth.uid == uid);
      allow create, update: if isSignedIn() && request.auth.uid == uid;
      allow delete: if isAdmin();

      match /quizAttempts/{attemptId} {
        allow read: if isAdmin() || (isSignedIn() && request.auth.uid == uid);
        allow create: if isSignedIn() && request.auth.uid == uid;
        allow update, delete: if isAdmin();
      }
    }

    // Admin marker docs (created manually or by migration tooling)
    match /admins/{uid} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }
  }
}

